# ===== LLM (um dos dois; OpenRouter é o default e o barato) =====
# OpenRouter (openrouter.ai/keys) - da acesso aos modelos chineses baratos.
# Default: moonshotai/kimi-k2.6 (~$0.55/$3.20 por 1M tokens, otimo pra escrita)
OPENROUTER_API_KEY=
# Alternativa premium: API da Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=
# Overrides opcionais:
# LLM_PROVIDER=openrouter | anthropic (auto-detecta pela chave presente)
# MODEL_ID=moonshotai/kimi-k2.6 | deepseek/deepseek-chat | z-ai/glm-4.6 | claude-opus-4-8 ...

# ===== Zernio (obrigatorio) - publica os posts =====
ZERNIO_API_KEY=
ZERNIO_PROFILE_ID=6a46883317acea1f59ad3cbe

# ===== Vercel Blob (auto-preenchido pelo `vercel env pull`) =====
BLOB_READ_WRITE_TOKEN=
# Segmento secreto dos paths no Blob (store é público; isto impede URL adivinhável)
BLOB_PATH_SECRET=

# ===== Seguranca =====
# Senha inicial do dashboard (bootstrap) - troque pela UI em ajustes > trocar senha
DASHBOARD_PASSWORD=
CRON_SECRET=
# URL publica estavel (usada pela cadeia de estagios pra se auto-invocar)
BASE_URL=https://motorx-opus.vercel.app

# ===== Opcionais =====
# Telegram (so se quiser alertas de erro no celular; o dashboard ja mostra tudo)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=8508456230
# Inbox de ideias via bot do Telegram (opcional; o inbox do dashboard ja cobre)
TELEGRAM_INBOX_BOT_TOKEN=
TELEGRAM_INBOX_CHAT_ID=8508456230
# twitterapi.io (leitura de trends + ancoras de voz ao vivo; sem ela usa fallback)
TWITTERAPI_IO_KEY=
