# API da Anthropic (obrigatorio) - console.anthropic.com
ANTHROPIC_API_KEY=

# Zernio (obrigatorio) - publica os posts
ZERNIO_API_KEY=
ZERNIO_PROFILE_ID=6a46883317acea1f59ad3cbe

# Vercel Blob (auto-preenchido pelo `vercel env pull` apos criar o store)
BLOB_READ_WRITE_TOKEN=

# Telegram (notificacoes pro Victor + inbox de ideias)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=8508456230
TELEGRAM_INBOX_BOT_TOKEN=

# twitterapi.io (leitura do X: trends + ancoras de voz ao vivo)
TWITTERAPI_IO_KEY=

# Seguranca
DASHBOARD_PASSWORD=
CRON_SECRET=

# Modelo (opcional, default claude-opus-4-8)
MODEL_ID=claude-opus-4-8

# Segmento secreto dos paths no Blob (store é público; isto impede URL adivinhável)
BLOB_PATH_SECRET=
# Chat autorizado do inbox (mensagens de outros chats são descartadas)
TELEGRAM_INBOX_CHAT_ID=8508456230
